# Supabase Configuration
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"


# Frontend Public Keys (same as above for Vite)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Google Auth
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
VITE_GOOGLE_AUTH_PROXY="https://designarena.ai/auth/google/callback"

# Admin Credentials (Demo)
ADMIN_EMAIL="admin@techsphere.com"
ADMIN_PASSWORD="admin123"
VITE_ADMIN_EMAIL="admin@techsphere.com"
AUTO_CREATE_ADMIN="false"
HEALTH_PROTECT="true"
HEALTH_TOKEN="change-me"

# Public App URL (for share links)
PUBLIC_APP_URL="http://localhost:5173"
VITE_PUBLIC_APP_URL="http://localhost:5173"

# Development Mode (Set to true to see OTP in API response for testing)
DEV_MODE="true"
VITE_ALLOWED_DOMAINS="gmail.com,outlook.com,ietddu.ac.in,ddugu.ac.in"

# SMTP Credentials
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="no-reply@designarena.com"
SMTP_PASS="your-app-password"
SMTP_FROM="TechSphere <no-reply@designarena.com>"
